{
  "name": "sample-ci-cd",
  "version": "1.0.0",
  "description": "A simple click-counter demo for teaching CI/CD with GitHub Actions",
  "private": true,
  "scripts": {
    "start": "npx serve src -l 8080",
    "test": "jest --config jest.config.js",
    "test:integration": "npx cypress run",
    "lhci": "lhci autorun",
    "lhci:monitor": "lhci collect --url=\"$LHCI_URL\" --numberOfRuns=3 --settings.preset=desktop && lhci upload --target=filesystem --outputDir=./lighthouse-reports",
    "prepare": "husky"
  },
  "devDependencies": {
    "cypress": "^13.15.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "@lhci/cli": "^0.15.0",
    "serve": "^14.2.0"
  }
}
